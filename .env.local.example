# Brevo (Sendinblue) - Récupère ta clé sur app.brevo.com > Compte > API
BREVO_API_KEY=ta_cle_brevo_ici

# Ton email expéditeur vérifié sur Brevo
BREVO_SENDER_EMAIL=info@nerixi.com
BREVO_SENDER_NAME=Nerixi

# Stripe - dashboard.stripe.com > Développeurs > Clés API
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Auth (optionnel - sinon défaut: info@nerixi.com / Nerixi@CRM-2026!)
# AUTH_EMAIL=info@nerixi.com
# AUTH_PASSWORD=ChangeMoiEnProd!
# AUTH_SECRET=une_chaine_aleatoire_de_32+_caracteres

# n8n - Webhook d'onboarding automatisé
# 1. Crée un workflow n8n démarré par "Webhook" en mode POST
# 2. Copie l'URL et colle-la ici
# 3. (recommandé) Définis un secret partagé pour signer les requêtes
N8N_ONBOARDING_WEBHOOK_URL=https://n8n.tondomaine.com/webhook/nerixi-onboarding
N8N_WEBHOOK_SECRET=un_secret_partage_aleatoire
